{
  "name": "@monzim/calendar",
  "version": "1.0.0",
  "description": "Routine-native, headless-first React calendar library. One generic event model → day / today / week / month views, recurrence, and one-click export to Google / Apple / Outlook.",
  "type": "module",
  "license": "MIT",
  "author": "Azraf Al Monzim",
  "homepage": "https://github.com/monzim/calendar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monzim/calendar.git"
  },
  "keywords": [
    "react",
    "calendar",
    "scheduler",
    "routine",
    "timetable",
    "recurrence",
    "rrule",
    "ics",
    "week-view",
    "shadcn",
    "tailwind"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./core": {
      "types": "./dist/core/index.d.mts",
      "import": "./dist/core/index.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.mts",
      "import": "./dist/react/index.mjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.mts",
      "import": "./dist/ui/index.mjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm build:js && pnpm build:css",
    "build:js": "tsdown",
    "build:css": "tailwindcss -i ./src/ui/styles.css -o ./dist/styles.css --minify",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint:pkg": "publint && attw --pack --profile esm-only --exclude-entrypoints ./styles.css"
  },
  "peerDependencies": {
    "react": ">=18.3.0 <20.0.0",
    "react-dom": ">=18.3.0 <20.0.0"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "rrule": "^2.8.1",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.1",
    "@tailwindcss/cli": "^4.3.0",
    "publint": "^0.3.5",
    "tailwindcss": "^4.3.0",
    "tsdown": "^0.22.0",
    "tw-animate-css": "^1.4.0"
  }
}
