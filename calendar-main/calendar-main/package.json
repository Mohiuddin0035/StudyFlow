{
  "name": "calendar-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm --filter @monzim/calendar build",
    "build:demo": "pnpm --filter @monzim/calendar build:css && pnpm --filter web build",
    "dev": "pnpm --filter @monzim/calendar build:css && pnpm --filter web dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint:pkg": "pnpm --filter @monzim/calendar lint:pkg"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}
